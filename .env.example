# playwright-devtools-mcp 環境変数

# MCP Bearer認証トークン (Claude.AIコネクタ用)
# 生成: openssl rand -hex 32
MCP_AUTH_TOKEN=

# GitHub Webhook シークレット (CI/CDデプロイ用)
# GitHubリポジトリ Settings → Webhooks で設定したシークレットと一致させる
# 生成: openssl rand -hex 32
WEBHOOK_SECRET=

# デプロイ対象ブランチ (default: main)
DEPLOY_BRANCH=main

# サーバー設定
PORT=3100
HOST=0.0.0.0
