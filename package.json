{
  "name": "playwright-devtools-mcp",
  "version": "1.0.0",
  "description": "Playwright MCP server with full Chrome DevTools Protocol support for browser automation, debugging, network analysis, and performance monitoring",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "keywords": [
    "mcp",
    "playwright",
    "devtools",
    "browser-automation",
    "debugging",
    "chrome-devtools-protocol"
  ],
  "author": "DaisukeHori",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "express": "^5.1.0",
    "playwright": "^1.59.1",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^4.1.4",
    "typescript": "^5.7.0",
    "vitest": "^4.1.4"
  }
}
